# === Required (pick at least one pipeline) ===
NVIDIA_API_KEY=
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=

# === Deployment ===
DOMAIN=prove.example.com     # Your domain (Caddy auto-HTTPS)
NEO4J_PASSWORD=changeme          # Change this!

# === Optional overrides ===
# CHAT_PROVIDER=anthropic        # nim (default) or anthropic
# EMBED_PROVIDER=voyage          # nim (default) or voyage
# CLAUDE_MODEL=claude-haiku-4-5-20251001
# NEO4J_URI=bolt://neo4j:7687   # Set automatically in docker-compose.prod.yml
# NEO4J_USER=neo4j
# DB_PATH=data/prove.db
# GITHUB_TOKEN=                  # For private repo access during ingestion
# LOG_LEVEL=INFO
# CDN_BASE=https://cdn.prove.codeblackwell.ai  # CloudFront CDN (optional)
