# PROVE — portfolio AI agent
prove.codeblackwell.ai {
	reverse_proxy app:7860

	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		-Server
	}

	encode gzip

	log {
		output file /data/access.log
		format json
	}
}

# Personal site — React SPA served from /opt/portfolio
codeblackwell.ai, www.codeblackwell.ai {
	root * /srv/portfolio
	file_server
	try_files {path} /index.html

	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		-Server
	}

	encode gzip

	log {
		output file /data/portfolio-access.log
		format json
	}
}
