# PROVE — portfolio AI agent
prove.codeblackwell.ai {
	# Static assets: serve directly from filesystem with pre-compression
	handle /static/* {
		root * /srv/app
		file_server {
			precompressed br gzip
		}
		@versioned query v=*
		header @versioned Cache-Control "public, max-age=31536000, immutable"
		@unversioned not query v=*
		header @unversioned Cache-Control "public, max-age=604800"
	}

	# API: no caching
	handle /api/* {
		reverse_proxy app:7860
		header Cache-Control "no-store"
	}

	# Everything else proxied to FastAPI
	handle {
		reverse_proxy app:7860
	}

	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		-Server
	}

	log {
		output file /data/access.log
		format json
	}
}

# Personal site — React SPA served from /opt/portfolio
codeblackwell.ai, www.codeblackwell.ai {
	root * /srv/portfolio
	file_server
	try_files {path} /index.html

	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		-Server
	}

	encode gzip

	log {
		output file /data/portfolio-access.log
		format json
	}
}
